#!/usr/bin/env python3
"""json-echo binary: reads JSON request from stdin, writes JSON response to stdout."""
import json, sys

def main():
    req = json.loads(sys.stdin.read())
    op = req.get("operation", "")
    args = req.get("arguments", {})
    cfg = req.get("config", {})

    if op == "echo":
        msg = args.get("message", "")
        prefix = cfg.get("prefix", "")
        output = f"{prefix}{msg}" if prefix else msg
        json.dump({"output": output, "data": {"message": msg, "prefix": prefix}}, sys.stdout)
    else:
        json.dump({"error": f"unknown operation: {op}"}, sys.stdout)

if __name__ == "__main__":
    main()
